        <!-- 1r: valida credencials -->
        <handler>
            <handler-name>SecurityHandler</handler-name>
            <handler-class>com.mycompany.crud.soap.ws.SecurityHandler</handler-class>
        </handler>
        <!-- 2n: registra el missatge (només si passa la seguretat) -->
